# ── iWarehouse Messenger — environment template ────────────────────────────
# Copy to .env and change every secret before deploying.

# General
NODE_ENV=production
APP_URL=https://messenger.iwarehouse.local
TZ=Asia/Manila

# API
API_PORT=4000
WEB_PORT=3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=iwarehouse_messenger
POSTGRES_USER=iwm
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql://iwm:change-me-strong-db-password@postgres:5432/iwarehouse_messenger?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=iwm-minio-admin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=iwm-attachments

# Uploads
UPLOAD_MAX_MB=50

# Auth
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Login protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Seed admin (used once by `npm run db:seed`)
SEED_ADMIN_EMAIL=michael.yap@iwarehouse.ph
SEED_ADMIN_PASSWORD=ChangeMeNow!2026

# CORS (dev only; behind NGINX same-origin in production)
CORS_ORIGIN=http://localhost:3000

# Google sign-in ("Continue with Google" on the login page)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: {APP_URL}/api/auth/google/callback
# Leave blank to hide the Google button entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Allow unknown Google emails to self-register as MEMBER (true/false)
GOOGLE_AUTO_CREATE=false
# Optional: restrict self-registration to one email domain, e.g. iwarehouse.ph
GOOGLE_ALLOWED_DOMAIN=

# Web push (Phase 6) — generate once with: npx web-push generate-vapid-keys
# Leave empty to disable push (in-app notifications still work).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:it@iwarehouse.ph

# Antivirus (Phase 5) — hostname of the clamd container. Empty = scanning off.
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
